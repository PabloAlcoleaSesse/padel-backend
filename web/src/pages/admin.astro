---
import "../styles/global.css";

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Admin panel for Algete Padel Tour Masters." />
    <title>Admin · Algete Padel Tour Masters</title>
  </head>
  <body class="admin-page admin-locked" data-api-base={apiBaseUrl}>
    <section class="admin-lock" id="admin-lock">
      <form class="admin-lock-card" id="admin-lock-form">
        <p class="eyebrow">Acceso rápido</p>
        <h1>Código admin</h1>
        <p class="hint">Introduce el código para entrar al cuarto de admin.</p>
        <label class="field">
          <span>Código</span>
          <input name="access_code" type="password" autocomplete="current-password" required />
        </label>
        <button class="admin-button" type="submit">Entrar</button>
        <p class="admin-status" id="admin-lock-status"></p>
      </form>
    </section>

    <script type="module" src="/scripts/admin.js"></script>
  </body>
</html>
