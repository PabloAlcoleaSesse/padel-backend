---
import "../styles/global.css";

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Algete Padel Tour Masters tournament standings, results, bracket and champions." />
    <title>Algete Padel Tour Masters</title>
  </head>
  <body data-api-base={apiBaseUrl}>
    <main class="site-shell">
      <header class="hero" id="top">
        <img class="brand-mark nav-mark" src="/figma/mark-light.png" alt="" />
        <nav class="top-nav" aria-label="Secciones">
          <a href="#grupos">Grupos</a>
          <a href="#resultados">Resultados</a>
          <a href="#bracket">Bracket</a>
          <a href="#campeones">Campeones</a>
          <a href="/admin/">Admin</a>
        </nav>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">Torneo oficial</p>
            <h1>Algete<br />Padel Tour<br />Masters</h1>
            <img class="brand-mark hero-mark" src="/figma/mark-light.png" alt="" />
            <p class="intro">
              Clasificación, resultados, bracket y campeones conectados al backend del torneo.
            </p>
          </div>

          <aside class="event-meta" aria-label="Datos del torneo">
            <span>Fecha</span>
            <strong>16 / 06 / 2026</strong>
            <span>Ubicación</span>
            <strong>CD. Jarama<br />Algete</strong>
            <span>Estado</span>
            <strong id="tournament-status">Cargando</strong>
          </aside>
        </div>

        <div class="hero-actions">
          <a class="pill-button" href="#grupos">Ver clasificación</a>
          <a class="pill-button" href="#bracket">Ver bracket</a>
        </div>
      </header>

      <section class="section-block" id="grupos">
        <div class="section-kicker">
          <span>Fase 01</span>
          <span>Grupos</span>
        </div>
        <h2>Clasificación<br />grupo único</h2>
        <div class="groups-grid" id="groups-grid" aria-live="polite"></div>
      </section>

      <section class="section-block" id="resultados">
        <div class="section-kicker">
          <span>Fase 02</span>
          <span>Resultados</span>
        </div>
        <h2>Resultados<br />fase de grupos</h2>
        <div class="matches-grid" id="results-grid" aria-live="polite"></div>
      </section>

      <section class="section-block" id="bracket">
        <div class="section-kicker">
          <span>Fase 03</span>
          <span>Bracket</span>
        </div>
        <h2>Camino a<br />la victoria</h2>
        <div class="bracket-grid" id="bracket-grid" aria-live="polite"></div>
      </section>

      <section class="section-block champions-section" id="campeones">
        <div class="section-kicker">
          <span>Fase 04</span>
          <span>Podio</span>
        </div>
        <h2>Los<br />campeones</h2>
        <div class="podium-grid" id="podium-grid" aria-live="polite"></div>
      </section>

      <footer class="site-footer">
        <div class="footer-brand">
          <strong>Algete<br />Padel Tour<br />Masters</strong>
          <img class="brand-mark footer-mark" src="/figma/mark-dark.png" alt="" />
        </div>
        <span>Organización<br />Org. Alcoholíficos Anónimos Melendez Pelayo</span>
        <span>APT © 2026<br />Ningún derecho reservado</span>
      </footer>
    </main>

    <script type="module" src="/scripts/site.js"></script>
  </body>
</html>
